{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "resolveJsonModule": true,
  },
  "include": ["src", "vite.config.ts"]
}